# ── BuyLow API (Render Web Service: buylow-api) ─────────────────

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (required)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/buylow?retryWrites=true&w=majority
MONGODB_URI=

# Auth — use a long random string (32+ chars). Render can auto-generate JWT_SECRET.
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Public URL of THIS backend (no trailing slash)
# Example: https://buylow-api.onrender.com
API_BASE_URL=

# Allowed frontend origins — comma-separated, NO trailing slashes
# Must include BOTH store + admin URLs after deploy:
# Example: https://buylow-store.onrender.com,https://buylow-admin.onrender.com
CLIENT_URL=

# Admin login (change password before going live)
ADMIN_EMAIL=admin@buylow.store
ADMIN_PASSWORD=

# Razorpay (optional — checkout works in test/simulated mode without keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Set false when store is a separate Render static site (recommended)
SERVE_CLIENT=false

# Google Sign-In — OAuth 2.0 Web Client ID (same value as VITE_GOOGLE_CLIENT_ID)
# Authorized JavaScript origins: http://localhost:5173 + your store URL
GOOGLE_CLIENT_ID=