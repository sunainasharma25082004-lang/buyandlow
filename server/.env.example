# Server
PORT=5000
NODE_ENV=development

# Database (required in production)
MONGODB_URI=mongodb://127.0.0.1:27017/truemart

# Auth (required in production — use a strong 32+ char secret)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=30d

# Public API URL for uploaded images (e.g. https://api.truemart.com)
API_BASE_URL=http://localhost:5000

# Allowed frontend origins, comma-separated (required in production)
# Example: https://truemart.com,https://admin.truemart.com
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Razorpay payment gateway
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here