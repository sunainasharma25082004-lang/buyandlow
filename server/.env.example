# ── Local development (copy to .env) ─────────────────────────────
#   PowerShell:  .\scripts\setup-env.ps1
#   Or manually: copy this file to server\.env and fill in values below

PORT=5000
NODE_ENV=development

# MongoDB Atlas or local: mongodb://127.0.0.1:27017/buylow
MONGODB_URI=

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Local — optional (defaults work for npm run dev in server/)
# API_BASE_URL=http://localhost:5000
# CLIENT_URL=http://localhost:5173,http://localhost:5174,http://localhost:8081

ADMIN_EMAIL=admin@buylow.store
ADMIN_PASSWORD=BuylowAdmin2026

# Razorpay test keys (optional — checkout works in simulated mode without these)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

SERVE_CLIENT=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_ANDROID_CLIENT_ID=   (same Android client ID as app — for phone sign-in token verify)

# ── Production (Render Web Service: buylow-api) ─────────────────

# NODE_ENV=production
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/buylow?retryWrites=true&w=majority
# JWT_SECRET=
# API_BASE_URL=https://buylow-api.onrender.com
# CLIENT_URL=https://buylow-store.onrender.com,https://buylow-admin.onrender.com
# SERVE_CLIENT=false