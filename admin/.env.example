# ── BuyLow Admin (Render Static Site: buylow-admin) ─────────────

# Local dev — Vite proxy handles /api and /uploads (keep both lines for local)
VITE_API_URL=/api
VITE_STORE_URL=http://localhost:5173

# Production — your backend URL + /api (set in Render dashboard)
# Example: https://buylow-api.onrender.com/api
VITE_API_URL=

# Customer store URL (sidebar "View Store" link)
# Example: https://buylow-store.onrender.com
VITE_STORE_URL=

# Optional — only if API URL does not end with /api
# VITE_API_ORIGIN=https://buylow-api.onrender.com