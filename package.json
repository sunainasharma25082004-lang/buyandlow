{
  "name": "buylow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run admin\"",
    "client": "npm run dev --prefix client",
    "admin": "npm run dev --prefix admin",
    "server": "npm run dev --prefix server",
    "seed": "npm run seed --prefix server",
    "build": "npm run build:client && npm run build:admin && npm run build:server",
    "build:client": "npm install --prefix client --include=dev && npm run build --prefix client",
    "build:admin": "npm install --prefix admin --include=dev && npm run build --prefix admin",
    "build:server": "npm install --prefix server --omit=dev",
    "start": "npm run start --prefix server",
    "preview:client": "npm run preview --prefix client",
    "preview:admin": "npm run preview --prefix admin"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.1",
    "react-native-razorpay": "^3.0.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-redux": "^9.3.0"
  }
}
