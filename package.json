{
  "name": "truemart",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run admin\"",
    "client": "vite",
    "admin": "npm run dev --prefix admin",
    "server": "npm run dev --prefix server",
    "seed": "node server/scripts/seed.js",
    "build": "npm install --include=dev && npm install --prefix server --omit=dev && npx vite build",
    "start": "node server/server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.2"
  }
}
