# ── Local development (copy to .env) ─────────────────────────────
#   PowerShell:  .\scripts\setup-env.ps1
#   Vite dev proxy forwards /api → http://localhost:5000

VITE_API_URL=/api

# Google Sign-In (optional — same Client ID as server GOOGLE_CLIENT_ID)
# VITE_GOOGLE_CLIENT_ID=

# ── Production (Render Static Site: buylow-store) ─────────────
# Set in Render dashboard:

# VITE_API_URL=https://buylow-api.onrender.com/api
# VITE_GOOGLE_CLIENT_ID=

# Optional — only if API URL does not end with /api
# VITE_API_ORIGIN=https://buylow-api.onrender.com