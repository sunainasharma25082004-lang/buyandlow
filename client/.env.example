# ── BuyLow Store (Render Static Site: buylow-store) ─────────────

# Local dev — Vite proxy handles /api
# VITE_API_URL=/api

# Production — your backend URL + /api (set in Render dashboard)
# Example: https://buylow-api.onrender.com/api
VITE_API_URL=

# Optional — only if API URL does not end with /api
# VITE_API_ORIGIN=https://buylow-api.onrender.com

# Google Sign-In (same Client ID as server GOOGLE_CLIENT_ID)
# Create at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=