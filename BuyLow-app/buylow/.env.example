# ── Local development (copy to .env) ─────────────────────────────
#   PowerShell (repo root):  .\scripts\setup-env.ps1
#   Phone on same WiFi:      .\scripts\sync-api-env.ps1
#   Tunnel for phone:        npm run start:tunnel (auto-updates this file)

# Expo web — uses localhost (see config/api.ts)
# EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Phone / emulator on same WiFi — replace with your PC IP
# EXPO_PUBLIC_API_URL=http://192.168.1.19:5000/api

# Localtunnel (run server + api-tunnel.js first)
# EXPO_PUBLIC_API_URL=https://your-name.loca.lt/api

# Production API (Render)
# EXPO_PUBLIC_API_URL=https://buylow-api.onrender.com/api

# Optional — only for npm run start:ngrok
# NGROK_AUTHTOKEN=your_token_here

# Google Sign-In — OAuth 2.0 Web Client ID (same value as server GOOGLE_CLIENT_ID)
# Create at: https://console.cloud.google.com/apis/credentials
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# For phone (Expo Go) — can use same web ID in dev, or create Android/iOS OAuth clients:
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=